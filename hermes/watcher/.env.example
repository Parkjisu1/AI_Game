# ProjectHub Watcher 환경 변수 템플릿
# Mother에 배포 시 ~/.hermes/watcher/.env 로 복사 + 실제 값 기입
# systemd service에서 EnvironmentFile로 로드

# ──────────────────────────────────────────
# 필수
# ──────────────────────────────────────────

# MongoDB Atlas 연결 문자열 (ProjectHub의 .env.local에서 복사)
MONGODB_URI=mongodb+srv://USER:PASS@db.qwzflco.mongodb.net/?retryWrites=true&w=majority

# DB 이름 (ProjectHub와 동일하게 aigame)
MONGODB_DB=aigame

# ──────────────────────────────────────────
# 선택
# ──────────────────────────────────────────

# Hermes 메모리 루트 (기본값이 맞으면 생략 가능)
HERMES_MEMORY_ROOT=/home/aimed/.hermes/memories

# user_registry.yaml 위치 (생략 시 MEMORY_ROOT/user_registry.yaml 사용)
HERMES_USER_REGISTRY=/home/aimed/.hermes/memories/user_registry.yaml

# assignee에 올 수 있는 이름들 (콤마 구분, 대소문자 무시)
HERMES_ASSIGNEE_NAMES=hermes,Hermes,헤르메스,hermes-bot

# 활성 Stage (콤마 구분 숫자). 1,2,3만 설정하면 Stage 4+ 작업은 review로
HERMES_ACTIVE_STAGES=1,2,3

# GameForge 소스 위치 (Mother에 rsync된 경로)
GAMEFORGE_ROOT=/home/aimed/gameforge

# 머신 B SSH 정보
MACHINE_B_HOST=user@100.92.43.9
MACHINE_B_PROJECT_DIR=C:/projects/balloonflow
MACHINE_B_UNITY_DIR=C:/projects/balloonflow/BalloonFlow

# GitHub 저장소 (PR 생성용)
GITHUB_REPO_OWNER=jisupark-tech
GITHUB_REPO_NAME=BalloonFlow
HERMES_BRANCH_PREFIX=hermes/

# ── 배포 검증 게이트 (per-gate kill-switch: off|warn|block) ──
# 롤백 = 해당 env를 off로, 재배포 불필요. 첫 배포는 항상 off/warn → 1주 측정 → block.
HERMES_AUTO_MERGE=true               # main 자동 머지 (false=PR만)
HERMES_MERGE_GATE=block              # Reviewer 거부 시 머지 차단 (off|warn|block). 현재 라이브 기본 block.
HERMES_COMPILE_GATE=off              # 컴파일 게이트 (off|warn|block). MCP-first→batch fallback→indeterminate(차단X). 구버전 HERMES_VERIFY_COMPILE 대체 예정
HERMES_SYMBOL_GATE=off               # 삭제심볼 회귀 게이트 (off|warn|block). 초기 removedFiles만, removedMethods는 warn
HERMES_CONTRACT_GATE=off             # 계약(_CONTRACTS.yaml) 회귀 게이트 (off|warn|block). 파일 존재 시에만
HERMES_BUILD_GATE=off                # Unity batchmode 빌드 게이트 (off|warn|block). unity repo만
HERMES_APPROVAL_GATE=off             # 위험 task 배포 전 Slack 사전승인 (off|warn|block). TTL 필수
HERMES_GROUNDING=off                 # DNA 1-hop 서브그래프 coder 프롬프트 주입 (on|off). join=code_base.fileId↔graph node.cls

# LiteLLM (OpenAI 키 도착 후 활성)
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=

# Claude CLI 타임아웃 (초)
CLAUDE_CLI_TIMEOUT_SEC=600

# Claude Code 우선 사용 (Hermes 건너뜀)
# Phase 1 권장값: true (Claude Max OAuth가 작동하지만 API extra_usage 쿼타 필요한 문제 회피)
# OpenAI 키 수령 후엔 false로 (LiteLLM + Hermes 정상 경로)
PREFER_CLAUDE_CODE=true

# 로그 레벨 — DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO
