<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-lg font-bold text-white"><i class="fa-solid fa-code text-blue-400 mr-2"></i>System</h1>
  </div>

  <!-- Settings Bar -->
  <div class="bg-gf-card border border-gf-border rounded-xl p-4 mb-5">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
      <div>
        <label class="text-[11px] text-gf-muted mb-1 block">Engine</label>
        <select id="engineSelect" class="w-full px-3 py-2 rounded-lg text-xs">
          <option value="unity">Unity (C#)</option>
          <option value="playable">Playable (HTML5)</option>
        </select>
      </div>
      <div>
        <label class="text-[11px] text-gf-muted mb-1 block">Genre</label>
        <select id="sysGenreSelect" class="w-full px-3 py-2 rounded-lg text-xs">
          <option value="Generic">Generic</option>
          <option value="RPG">RPG</option>
          <option value="Idle">Idle</option>
          <option value="Merge">Merge</option>
          <option value="SLG">SLG</option>
          <option value="Tycoon">Tycoon</option>
          <option value="Simulation">Simulation</option>
          <option value="Puzzle">Puzzle</option>
          <option value="Casual">Casual</option>
        </select>
      </div>
      <div>
        <label class="text-[11px] text-gf-muted mb-1 block">Resolution</label>
        <select id="resolutionSelect" class="w-full px-3 py-2 rounded-lg text-xs">
          <option value="1080x1920">1080 x 1920 (Portrait)</option>
          <option value="1920x1080">1920 x 1080 (Landscape)</option>
          <option value="1080x2400">1080 x 2400 (Tall)</option>
          <option value="2560x1440">2560 x 1440 (QHD)</option>
          <option value="custom">Custom...</option>
        </select>
      </div>
      <div id="customResolution" class="hidden">
        <label class="text-[11px] text-gf-muted mb-1 block">Custom (WxH)</label>
        <input type="text" id="customResInput" placeholder="1080x1920"
          class="w-full px-3 py-2 bg-gf-surface border border-gf-border rounded-lg text-xs text-white focus:border-gf-accent focus:outline-none">
      </div>
    </div>
  </div>

  <div class="grid lg:grid-cols-12 gap-5">
    <!-- Left: Design File Attachment -->
    <div class="lg:col-span-3">
      <div class="bg-gf-card border border-gf-border rounded-xl p-4">
        <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">Design Files</h3>

        <!-- Drop Zone -->
        <div id="sysDropZone" class="drop-zone rounded-lg p-6 text-center cursor-pointer mb-3"
          onclick="document.getElementById('sysFileInput').click()">
          <i class="fa-solid fa-cloud-arrow-up text-2xl text-gf-muted mb-2"></i>
          <p class="text-xs text-gf-muted">Drag & Drop or Click</p>
          <p class="text-[10px] text-zinc-600 mt-1">.yaml .json .txt</p>
        </div>
        <input type="file" id="sysFileInput" class="hidden" multiple accept=".yaml,.yml,.json,.txt">

        <!-- URL Input -->
        <div class="mb-3">
          <div class="flex gap-2">
            <input type="text" id="sysUrlInput" placeholder="Paste URL..."
              class="flex-1 px-2 py-1.5 bg-gf-surface border border-gf-border rounded-lg text-[11px] text-white focus:border-gf-accent focus:outline-none">
            <button onclick="addUrlFile()" class="px-2 py-1.5 bg-gf-surface border border-gf-border rounded-lg text-[11px] text-gf-accent hover:bg-gf-hover transition-colors">
              <i class="fa-solid fa-plus"></i>
            </button>
          </div>
        </div>

        <!-- Attached Files List -->
        <div id="sysAttachedFiles" class="space-y-1.5 max-h-[200px] overflow-y-auto">
          <p class="text-[11px] text-gf-muted text-center py-2">No files attached</p>
        </div>

        <hr class="border-gf-border my-3">

        <!-- Generate Button -->
        <button onclick="generateCode()" id="codeGenerateBtn"
          class="w-full py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-colors text-sm">
          <i class="fa-solid fa-terminal mr-1.5"></i>Generate Code
        </button>
      </div>
    </div>

    <!-- Center: Code DB Browser -->
    <div class="lg:col-span-4">
      <div class="bg-gf-card border border-gf-border rounded-xl p-4">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Code DB</h3>
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="checkbox" id="selectAllCode" checked class="rounded">
            <span class="text-[11px] text-gf-muted">Select All</span>
          </label>
        </div>

        <!-- Layer Filter -->
        <div class="flex flex-wrap gap-1.5 mb-3" id="codeLayerFilters">
          <button class="filter-btn active" data-layer="all">All</button>
          <button class="filter-btn" data-layer="Core">Core</button>
          <button class="filter-btn" data-layer="Domain">Domain</button>
          <button class="filter-btn" data-layer="Game">Game</button>
        </div>

        <!-- Search -->
        <input type="text" id="codeSearchInput" placeholder="Search system/file..."
          class="w-full px-3 py-2 bg-gf-surface border border-gf-border rounded-lg text-xs text-white placeholder-gf-muted focus:border-gf-accent focus:outline-none mb-3">

        <!-- Code DB List -->
        <div id="codeDbList" class="space-y-1.5 max-h-[450px] overflow-y-auto pr-1">
          <div class="text-center py-8 text-gf-muted text-xs">Select a genre to load Code DB</div>
        </div>

        <div class="mt-2 flex items-center justify-between">
          <span id="codeSelectedCount" class="text-[11px] text-gf-muted">0 selected</span>
          <button onclick="loadCodeDb()" class="text-xs text-blue-400 hover:text-blue-300 transition-colors">
            <i class="fa-solid fa-sync mr-1"></i>Refresh
          </button>
        </div>
      </div>
    </div>

    <!-- Right: UI Reference + Preview -->
    <div class="lg:col-span-5 space-y-5">
      <!-- UI Reference Images -->
      <div class="bg-gf-card border border-gf-border rounded-xl p-4">
        <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">UI Reference Images</h3>
        <div id="uiRefDropZone" class="drop-zone rounded-lg p-4 text-center cursor-pointer"
          onclick="document.getElementById('uiRefInput').click()">
          <i class="fa-solid fa-image text-xl text-gf-muted mb-1"></i>
          <p class="text-[11px] text-gf-muted">Drag & Drop reference images</p>
        </div>
        <input type="file" id="uiRefInput" class="hidden" multiple accept="image/*">
        <div id="uiRefList" class="flex flex-wrap gap-2 mt-2"></div>
      </div>

      <!-- Code Preview -->
      <div id="codeResults" class="hidden bg-gf-card border border-gf-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Generated Code</h3>
          <div class="flex items-center gap-3">
            <button onclick="prevCodeResult()" class="w-8 h-8 rounded-lg bg-gf-surface hover:bg-gf-hover border border-gf-border flex items-center justify-center text-zinc-400 hover:text-white transition-colors">
              <i class="fa-solid fa-chevron-left text-xs"></i>
            </button>
            <span id="codeResultIndex" class="text-xs text-zinc-400">1 / 1</span>
            <button onclick="nextCodeResult()" class="w-8 h-8 rounded-lg bg-gf-surface hover:bg-gf-hover border border-gf-border flex items-center justify-center text-zinc-400 hover:text-white transition-colors">
              <i class="fa-solid fa-chevron-right text-xs"></i>
            </button>
          </div>
        </div>
        <div id="codeResultTitle" class="text-sm font-medium text-white mb-2 font-mono"></div>
        <div id="codeResultContent" class="code-preview bg-gf-dark rounded-lg max-h-[400px] overflow-y-auto">
          <pre><code class="language-csharp"></code></pre>
        </div>
        <div class="mt-4 flex justify-end">
          <button onclick="downloadCodeZip()" class="px-4 py-2 bg-gf-surface hover:bg-gf-hover border border-gf-border text-zinc-300 rounded-lg text-sm transition-colors">
            <i class="fa-solid fa-file-zipper mr-1.5 text-blue-400"></i>ZIP Download
          </button>
        </div>
      </div>

      <!-- Progress -->
      <div id="codeProgress" class="hidden bg-gf-card border border-gf-border rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-5 h-5 border-2 border-blue-400 border-t-transparent rounded-full spinner"></div>
          <span class="text-sm text-white font-medium">Generating code...</span>
        </div>
        <div class="w-full bg-gf-surface rounded-full h-1.5">
          <div id="codeProgressBar" class="progress-animated h-1.5 rounded-full" style="width: 30%"></div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script src="/js/system.js"></script>
