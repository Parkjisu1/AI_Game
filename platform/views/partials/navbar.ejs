  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 nav-blur bg-gf-dark/90 border-b border-gf-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between h-14">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="drop-shadow-sm">
            <path d="M12 2L22 8L12 14L2 8L12 2Z" fill="#d97706"/>
            <path d="M12 14L22 8V16L12 22V14Z" fill="#f59e0b" opacity="0.75"/>
            <path d="M12 14L2 8V16L12 22V14Z" fill="#d97706" opacity="0.45"/>
          </svg>
          <span class="text-base font-bold text-white group-hover:text-gf-accent transition-colors">GameForge</span>
