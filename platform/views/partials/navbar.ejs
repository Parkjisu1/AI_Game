        </a>

        <!-- Desktop Nav Links -->
        <div class="hidden lg:flex items-center gap-1">
          <a href="/" class="nav-link px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
            <%= currentPath === '/' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400 hover:text-white hover:bg-gf-surface' %>">
            <i class="fa-solid fa-gauge-high mr-1.5"></i>Dashboard
          </a>
          <a href="/design" class="nav-link px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
            <%= currentPath === '/design' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400 hover:text-white hover:bg-gf-surface' %>">
            <i class="fa-solid fa-pencil-ruler mr-1.5"></i>Design
          </a>
          <a href="/system" class="nav-link px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
            <%= currentPath === '/system' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400 hover:text-white hover:bg-gf-surface' %>">
            <i class="fa-solid fa-code mr-1.5"></i>System
          </a>
          <a href="/embedding" class="nav-link px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
            <%= currentPath === '/embedding' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400 hover:text-white hover:bg-gf-surface' %>">
            <i class="fa-solid fa-database mr-1.5"></i>Embedding
          </a>
          <% if (user && user.isAdmin) { %>
          <a href="/users" class="nav-link px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
            <%= currentPath === '/users' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400 hover:text-white hover:bg-gf-surface' %>">
            <i class="fa-solid fa-users-gear mr-1.5"></i>Users
          </a>
          <% } %>
          <a href="/review" class="nav-link px-3 py-1.5 rounded-lg text-sm font-medium transition-colors relative
            <%= currentPath === '/review' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400 hover:text-white hover:bg-gf-surface' %>">
            <i class="fa-solid fa-check-double mr-1.5"></i>Review
            <span id="pendingBadge" class="hidden absolute -top-1 -right-1 bg-gf-danger text-white text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center badge-pulse"></span>
          </a>
          <a href="/log" class="nav-link px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
            <%= currentPath === '/log' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400 hover:text-white hover:bg-gf-surface' %>">
            <i class="fa-solid fa-clock-rotate-left mr-1.5"></i>Log
          </a>
        </div>

        <!-- Right Side -->
        <div class="flex items-center gap-3">
          <% if (user) { %>
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full bg-gradient-to-br from-gf-accent to-gf-accent2 flex items-center justify-center text-white text-xs font-bold">
              <%= user.displayName ? user.displayName[0].toUpperCase() : 'U' %>
            </div>
            <span class="hidden sm:block text-sm text-zinc-300"><%= user.displayName %></span>
            <% if (user.isAdmin) { %>
            <span class="text-[10px] font-bold text-gf-accent bg-gf-accent/10 px-1.5 py-0.5 rounded">ADMIN</span>
            <% } %>
          </div>
          <button onclick="logout()" class="text-zinc-500 hover:text-gf-danger transition-colors text-sm" title="Logout">
            <i class="fa-solid fa-right-from-bracket"></i>
          </button>
          <% } %>

          <!-- Mobile menu button -->
          <button id="mobileMenuBtn" class="lg:hidden text-zinc-400 hover:text-white transition-colors">
            <i class="fa-solid fa-bars text-lg"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobileMenu" class="lg:hidden hidden border-t border-gf-border bg-gf-dark/95">
      <div class="px-4 py-3 space-y-1">
        <a href="/" class="block px-3 py-2 rounded-lg text-sm <%= currentPath === '/' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400' %>">
          <i class="fa-solid fa-gauge-high mr-2 w-5"></i>Dashboard
        </a>
        <a href="/design" class="block px-3 py-2 rounded-lg text-sm <%= currentPath === '/design' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400' %>">
          <i class="fa-solid fa-pencil-ruler mr-2 w-5"></i>Design
        </a>
        <a href="/system" class="block px-3 py-2 rounded-lg text-sm <%= currentPath === '/system' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400' %>">
          <i class="fa-solid fa-code mr-2 w-5"></i>System
        </a>
        <a href="/embedding" class="block px-3 py-2 rounded-lg text-sm <%= currentPath === '/embedding' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400' %>">
          <i class="fa-solid fa-database mr-2 w-5"></i>Embedding
        </a>
        <% if (user && user.isAdmin) { %>
        <a href="/users" class="block px-3 py-2 rounded-lg text-sm <%= currentPath === '/users' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400' %>">
          <i class="fa-solid fa-users-gear mr-2 w-5"></i>Users
        </a>
        <% } %>
        <a href="/review" class="block px-3 py-2 rounded-lg text-sm <%= currentPath === '/review' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400' %>">
          <i class="fa-solid fa-check-double mr-2 w-5"></i>Review
        </a>
        <a href="/log" class="block px-3 py-2 rounded-lg text-sm <%= currentPath === '/log' ? 'text-gf-accent bg-gf-accent/10' : 'text-zinc-400' %>">
          <i class="fa-solid fa-clock-rotate-left mr-2 w-5"></i>Log
        </a>
      </div>
    </div>
  </nav>

  <!-- Spacer for fixed nav -->
  <div class="h-14"></div>

  <style>
    @keyframes wave {
      0%, 100% { height: 40%; }
      50% { height: 100%; }
    }
  </style>

  <script>
    // Mobile menu toggle
    document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
      document.getElementById('mobileMenu').classList.toggle('hidden');
    });

    // Logout
    async function logout() {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/login';
    }

    // Load pending count for badge
    async function loadPendingBadge() {
      try {
        const res = await fetch('/api/stats');
        const data = await res.json();
        const badge = document.getElementById('pendingBadge');
        if (badge && data.pending > 0) {
          badge.textContent = data.pending > 9 ? '9+' : data.pending;
          badge.classList.remove('hidden');
        }
      } catch (e) { /* ignore */ }
    }
    if (document.querySelector('[data-auth="true"]') || document.querySelector('.nav-link')) {
      loadPendingBadge();
    }
  </script>
