<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GameForge Platform</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/csharp.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/yaml.min.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { inter: ['Inter', 'sans-serif'] },
          colors: {
            gf: {
              dark: '#0a0a0a',
              card: '#141414',
              border: '#1e1e1e',
              accent: '#d97706',
              accent2: '#f59e0b',
              hover: '#1a1a2e',
              muted: '#71717a',
              surface: '#18181b',
              success: '#22c55e',
              danger: '#ef4444',
              info: '#3b82f6',
            }
          }
        }
      }
    }
  </script>
  <style>
    * { font-family: 'Inter', sans-serif; }
    body { background: #0a0a0a; color: #e4e4e7; }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #141414; }
    ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #555; }

    /* Navbar blur */
    .nav-blur { backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }

    /* Card hover */
    .card-hover { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .card-hover:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(217, 119, 6, 0.15); border-color: #d97706; }

    /* Tab active */
    .tab-active { color: #d97706 !important; border-bottom: 2px solid #d97706; }

    /* Pulse glow */
    @keyframes pulseGlow {
      0%, 100% { box-shadow: 0 0 5px rgba(217, 119, 6, 0.3); }
      50% { box-shadow: 0 0 20px rgba(217, 119, 6, 0.6); }
    }
    .pulse-glow { animation: pulseGlow 3s ease-in-out infinite; }

    /* File drop zone */
    .drop-zone { border: 2px dashed #333; transition: all 0.3s ease; }
    .drop-zone.drag-over { border-color: #d97706; background: rgba(217, 119, 6, 0.05); }

    /* Spinner */
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner { animation: spin 1s linear infinite; }

    /* Progress bar */
    @keyframes progressPulse {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
    .progress-animated {
      background: linear-gradient(90deg, #d97706 0%, #f59e0b 50%, #d97706 100%);
      background-size: 200% 100%;
      animation: progressPulse 2s linear infinite;
    }

    /* Code preview */
    .code-preview pre { margin: 0; border-radius: 0.5rem; }
    .code-preview code { font-size: 0.8rem; line-height: 1.5; }

    /* Toast notification */
    .toast {
      position: fixed; bottom: 20px; right: 20px;
      transform: translateY(100px); opacity: 0;
      transition: all 0.3s ease;
      z-index: 9999;
    }
    .toast.show { transform: translateY(0); opacity: 1; }

    /* Badge pulse */
    .badge-pulse { animation: pulseGlow 2s ease-in-out infinite; }

    /* Scrollbar hide for horizontal scroll */
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

    /* Select/Dropdown dark styling */
    select {
      background-color: #141414;
      color: #e4e4e7;
      border: 1px solid #1e1e1e;
    }
    select:focus { border-color: #d97706; outline: none; }

    /* Checkbox custom */
    input[type="checkbox"] { accent-color: #d97706; }

    /* Filter button group */
    .filter-btn {
      padding: 0.375rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 500;
      border: 1px solid #1e1e1e;
      background: #141414;
      color: #71717a;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .filter-btn:hover { border-color: #d97706; color: #e4e4e7; }
    .filter-btn.active { background: #d97706; color: #fff; border-color: #d97706; }

    /* Expandable log row */
    .log-detail { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
    .log-detail.expanded { max-height: 300px; }
  </style>
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="bg-gf-dark text-zinc-200 font-inter min-h-screen">
