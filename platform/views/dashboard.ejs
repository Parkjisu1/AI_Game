<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
  <!-- Stats Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-3 mb-8">
    <div class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center">
          <i class="fa-solid fa-code text-blue-400"></i>
        </div>
        <div>
          <div class="text-xl font-bold text-white"><%= stats.codeBaseCount %></div>
          <div class="text-[11px] text-gf-muted">Code Base</div>
        </div>
      </div>
    </div>
    <div class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center">
          <i class="fa-solid fa-star text-emerald-400"></i>
        </div>
        <div>
          <div class="text-xl font-bold text-white"><%= stats.codeExpertCount %></div>
          <div class="text-[11px] text-gf-muted">Code Expert</div>
        </div>
      </div>
    </div>
    <div class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center">
          <i class="fa-solid fa-pencil-ruler text-purple-400"></i>
        </div>
        <div>
          <div class="text-xl font-bold text-white"><%= stats.designBaseCount %></div>
          <div class="text-[11px] text-gf-muted">Design Base</div>
        </div>
      </div>
    </div>
    <div class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center">
          <i class="fa-solid fa-award text-amber-400"></i>
        </div>
        <div>
          <div class="text-xl font-bold text-white"><%= stats.designExpertCount %></div>
          <div class="text-[11px] text-gf-muted">Design Expert</div>
        </div>
      </div>
    </div>
    <div class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-cyan-500/10 flex items-center justify-center">
          <i class="fa-solid fa-book text-cyan-400"></i>
        </div>
        <div>
          <div class="text-xl font-bold text-white"><%= stats.rulesCount %></div>
          <div class="text-[11px] text-gf-muted">Rules</div>
        </div>
      </div>
    </div>
    <div class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-rose-500/10 flex items-center justify-center">
          <i class="fa-solid fa-hourglass-half text-rose-400"></i>
        </div>
        <div>
          <div class="text-xl font-bold text-white"><%= stats.pendingCount %></div>
          <div class="text-[11px] text-gf-muted">Pending Review</div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <!-- Genre Distribution -->
    <div class="bg-gf-card border border-gf-border rounded-xl p-5">
      <h3 class="text-sm font-semibold text-white mb-4"><i class="fa-solid fa-chart-pie text-gf-accent mr-2"></i>Code DB - Genre Distribution</h3>
      <div class="space-y-2">
        <% const totalCode = genreDistribution.reduce((s, g) => s + g.count, 0) || 1; %>
        <% genreDistribution.forEach(g => { %>
        <div class="flex items-center gap-3">
          <span class="text-xs text-zinc-400 w-20 truncate"><%= g._id || 'Unknown' %></span>
          <div class="flex-1 bg-gf-surface rounded-full h-2">
            <div class="bg-gradient-to-r from-gf-accent to-gf-accent2 h-2 rounded-full" style="width: <%= Math.round(g.count / totalCode * 100) %>%"></div>
          </div>
          <span class="text-xs text-zinc-500 w-8 text-right"><%= g.count %></span>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Design Genre Distribution -->
    <div class="bg-gf-card border border-gf-border rounded-xl p-5">
      <h3 class="text-sm font-semibold text-white mb-4"><i class="fa-solid fa-chart-pie text-purple-400 mr-2"></i>Design DB - Genre Distribution</h3>
      <div class="space-y-2">
        <% const totalDesign = designGenreDistribution.reduce((s, g) => s + g.count, 0) || 1; %>
        <% designGenreDistribution.forEach(g => { %>
        <div class="flex items-center gap-3">
          <span class="text-xs text-zinc-400 w-20 truncate"><%= g._id || 'Unknown' %></span>
          <div class="flex-1 bg-gf-surface rounded-full h-2">
            <div class="bg-gradient-to-r from-purple-500 to-purple-400 h-2 rounded-full" style="width: <%= Math.round(g.count / totalDesign * 100) %>%"></div>
          </div>
          <span class="text-xs text-zinc-500 w-8 text-right"><%= g.count %></span>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="mt-6 grid grid-cols-2 lg:grid-cols-4 gap-3">
    <a href="/design" class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-lg bg-gf-accent/10 flex items-center justify-center group-hover:bg-gf-accent/20 transition-colors">
        <i class="fa-solid fa-wand-magic-sparkles text-gf-accent"></i>
      </div>
      <div>
        <div class="text-sm font-medium text-white">New Design</div>
        <div class="text-[11px] text-gf-muted">Generate game design</div>
      </div>
    </a>
    <a href="/system" class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center group-hover:bg-blue-500/20 transition-colors">
        <i class="fa-solid fa-terminal text-blue-400"></i>
      </div>
      <div>
        <div class="text-sm font-medium text-white">Generate Code</div>
        <div class="text-[11px] text-gf-muted">Create game systems</div>
      </div>
    </a>
    <a href="/review" class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center group-hover:bg-emerald-500/20 transition-colors">
        <i class="fa-solid fa-clipboard-check text-emerald-400"></i>
      </div>
      <div>
        <div class="text-sm font-medium text-white">Review Queue</div>
        <div class="text-[11px] text-gf-muted"><%= stats.pendingCount %> items pending</div>
      </div>
    </a>
    <a href="/log" class="bg-gf-card border border-gf-border rounded-xl p-4 card-hover flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-lg bg-cyan-500/10 flex items-center justify-center group-hover:bg-cyan-500/20 transition-colors">
        <i class="fa-solid fa-list-check text-cyan-400"></i>
      </div>
      <div>
        <div class="text-sm font-medium text-white">Activity Log</div>
        <div class="text-[11px] text-gf-muted">View all activities</div>
      </div>
    </a>
  </div>

  <!-- Recent Activity -->
  <div class="mt-6 bg-gf-card border border-gf-border rounded-xl p-5">
    <h3 class="text-sm font-semibold text-white mb-4"><i class="fa-solid fa-clock text-gf-accent mr-2"></i>Recent Activity</h3>
    <% if (recentLogs.length === 0) { %>
    <p class="text-sm text-gf-muted text-center py-8">No activity yet</p>
    <% } else { %>
    <div class="space-y-2">
      <% recentLogs.forEach(log => { %>
      <div class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gf-surface transition-colors">
        <div class="w-2 h-2 rounded-full flex-shrink-0
          <%= log.type === 'design' ? 'bg-purple-400' : log.type === 'system' ? 'bg-blue-400' : log.type === 'embedding' ? 'bg-emerald-400' : log.type === 'review' ? 'bg-amber-400' : 'bg-zinc-500' %>"></div>
        <span class="text-xs text-gf-muted w-28 flex-shrink-0"><%= new Date(log.timestamp).toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' }) %></span>
        <span class="text-xs font-medium text-zinc-300 w-16 flex-shrink-0"><%= log.username %></span>
        <span class="text-xs px-1.5 py-0.5 rounded font-medium flex-shrink-0
          <%= log.type === 'design' ? 'bg-purple-500/10 text-purple-400' : log.type === 'system' ? 'bg-blue-500/10 text-blue-400' : log.type === 'embedding' ? 'bg-emerald-500/10 text-emerald-400' : log.type === 'review' ? 'bg-amber-500/10 text-amber-400' : 'bg-zinc-500/10 text-zinc-400' %>"><%= log.type %></span>
        <span class="text-xs text-zinc-400 truncate"><%= log.action %></span>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
