<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-lg font-bold text-white"><i class="fa-solid fa-database text-emerald-400 mr-2"></i>Embedding</h1>
    <% if (user.isAdmin) { %>
    <span class="text-[10px] font-bold text-emerald-400 bg-emerald-400/10 px-2 py-1 rounded">DIRECT UPLOAD</span>
    <% } else { %>
    <span class="text-[10px] font-bold text-amber-400 bg-amber-400/10 px-2 py-1 rounded">REQUIRES ADMIN REVIEW</span>
    <% } %>
  </div>

  <!-- Upload Area -->
  <div class="bg-gf-card border border-gf-border rounded-xl p-5 mb-5">
    <div id="embDropZone" class="drop-zone rounded-xl p-12 text-center cursor-pointer"
      onclick="document.getElementById('embFileInput').click()">
      <div class="mb-3">
        <i class="fa-solid fa-cloud-arrow-up text-4xl text-gf-muted"></i>
      </div>
      <p class="text-sm text-zinc-300 font-medium">Drop files or folders here</p>
      <p class="text-xs text-gf-muted mt-1">Supports: .cs, .yaml, .yml, .json, .txt</p>
      <p class="text-[11px] text-zinc-600 mt-2">or click to browse</p>
    </div>
    <input type="file" id="embFileInput" class="hidden" multiple accept=".cs,.yaml,.yml,.json,.txt" webkitdirectory>
    <div class="flex gap-2 mt-3">
      <button onclick="document.getElementById('embFileInputFiles').click()"
        class="px-3 py-1.5 bg-gf-surface border border-gf-border rounded-lg text-xs text-zinc-300 hover:text-white hover:border-gf-accent transition-colors">
        <i class="fa-solid fa-file mr-1.5"></i>Select Files
      </button>
      <button onclick="document.getElementById('embFileInput').click()"
        class="px-3 py-1.5 bg-gf-surface border border-gf-border rounded-lg text-xs text-zinc-300 hover:text-white hover:border-gf-accent transition-colors">
        <i class="fa-solid fa-folder-open mr-1.5"></i>Select Folder
      </button>
    </div>
    <input type="file" id="embFileInputFiles" class="hidden" multiple accept=".cs,.yaml,.yml,.json,.txt">
  </div>

  <div class="grid lg:grid-cols-2 gap-5">
    <!-- File Preview -->
    <div class="bg-gf-card border border-gf-border rounded-xl p-5">
      <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">
        File Preview
        <span id="embFileCount" class="ml-2 text-gf-accent">0 files</span>
      </h3>
      <div id="embFileList" class="space-y-2 max-h-[500px] overflow-y-auto pr-1">
        <p class="text-sm text-gf-muted text-center py-12">No files uploaded yet</p>
      </div>
    </div>

    <!-- Structure Settings -->
    <div class="bg-gf-card border border-gf-border rounded-xl p-5">
      <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">Structure Settings</h3>

      <div class="space-y-3">
        <div>
          <label class="text-[11px] text-gf-muted mb-1 block">Target DB</label>
          <select id="embTargetDb" class="w-full px-3 py-2 rounded-lg text-xs">
            <option value="auto">Auto Detect</option>
            <option value="code_base">code_base (Code)</option>
            <option value="design_base">design_base (Design)</option>
          </select>
        </div>

        <div>
          <label class="text-[11px] text-gf-muted mb-1 block">Layer</label>
          <select id="embLayer" class="w-full px-3 py-2 rounded-lg text-xs">
            <option value="auto">Auto Detect</option>
            <option value="Core">Core</option>
            <option value="Domain">Domain</option>
            <option value="Game">Game</option>
          </select>
        </div>

        <div>
          <label class="text-[11px] text-gf-muted mb-1 block">Genre</label>
          <select id="embGenre" class="w-full px-3 py-2 rounded-lg text-xs">
            <option value="Generic">Generic</option>
            <option value="RPG">RPG</option>
            <option value="Idle">Idle</option>
            <option value="Merge">Merge</option>
            <option value="SLG">SLG</option>
            <option value="Tycoon">Tycoon</option>
            <option value="Simulation">Simulation</option>
            <option value="Puzzle">Puzzle</option>
            <option value="Casual">Casual</option>
          </select>
        </div>

        <div>
          <label class="text-[11px] text-gf-muted mb-1 block">Role (Code only)</label>
          <select id="embRole" class="w-full px-3 py-2 rounded-lg text-xs">
            <option value="auto">Auto Detect</option>
            <option value="Manager">Manager</option>
            <option value="Controller">Controller</option>
            <option value="Calculator">Calculator</option>
            <option value="Processor">Processor</option>
            <option value="Handler">Handler</option>
            <option value="Factory">Factory</option>
            <option value="Service">Service</option>
            <option value="Pool">Pool</option>
            <option value="State">State</option>
            <option value="Helper">Helper</option>
            <option value="Config">Config</option>
            <option value="UX">UX</option>
          </select>
        </div>

        <div>
          <label class="text-[11px] text-gf-muted mb-1 block">Domain (Design only)</label>
          <select id="embDomain" class="w-full px-3 py-2 rounded-lg text-xs">
            <option value="auto">Auto Detect</option>
            <option value="InGame">InGame</option>
            <option value="OutGame">OutGame</option>
            <option value="Balance">Balance</option>
            <option value="Content">Content</option>
            <option value="BM">BM</option>
            <option value="LiveOps">LiveOps</option>
            <option value="UX">UX</option>
            <option value="Social">Social</option>
            <option value="Meta">Meta</option>
          </select>
        </div>

        <label class="flex items-center gap-2 cursor-pointer mt-2">
          <input type="checkbox" id="embAutoClassify" checked class="rounded">
          <span class="text-xs text-zinc-300">Auto classify (current taxonomy)</span>
        </label>
      </div>

      <!-- Parse Preview -->
      <div id="embParsePreview" class="hidden mt-4 bg-gf-dark rounded-lg p-3 max-h-[200px] overflow-y-auto">
        <h4 class="text-[11px] text-gf-muted mb-2">Parse Preview</h4>
        <pre id="embParseContent" class="text-xs text-zinc-400 font-mono whitespace-pre-wrap"></pre>
      </div>

      <!-- Upload Button -->
      <button onclick="commitToMongo()" id="embCommitBtn" disabled
        class="w-full mt-4 py-3 bg-emerald-600 hover:bg-emerald-500 disabled:bg-gf-surface disabled:text-gf-muted text-white font-semibold rounded-lg transition-colors text-sm">
        <i class="fa-solid fa-rocket mr-1.5"></i>Upload to MongoDB
      </button>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script src="/js/embedding.js"></script>
