  "content": {
    "summary": "핵심 아이들 루프. 공급기가 제품을 생성하면, 머신이 타격하여 제품을 진행시키고,\n운송차가 수집하여 이익을 창출하는 자동화 생산 라인.",
    "flow": [
      {
        "step": "ProductSupplyer 생성",
        "detail": "supplyTime 간격으로 supplyAmount만큼 제품 생성 (maxSupplyNum 제한)",
        "class": "ProductSupplyer",
        "parameters": {
          "supply_time": "configurable interval (seconds)",
          "supply_amount": "products per cycle",
          "max_supply_num": "cap on simultaneous products"
        }
      },
      {
        "step": "Product 진행 (6단계)",
        "detail": "Product.MaxStepNum = 6, 각 단계에 HP 값 존재, 머신이 타격하여 다음 단계로 진행",
        "class": "Product",
        "parameters": {
          "max_step_num": 6,
          "hp_per_step": "double, varies by product type"
        }
      },
      {
        "step": "Transporter 수집",
        "detail": "3대 운송차 × 3슬롯, 완성된 제품을 Shipper로 이동",
        "class": "Transporter",
        "parameters": {
          "max_transporter_num": 3,
          "slots_per_transporter": 3
        }
      },
      {
        "step": "Profit 계산",
        "detail": "productTableProfit × (1 + credit + boosts + labBuffs) × moneyBoostFactor",
        "class": "ProductionLine.GetProfit"
      }
    ],
    "parameters": {
      "MaxFactoryNum": 4,
      "MaxSlotNum": 5,
      "MaxTransporterNum": 3,
      "DefaultMachineSpeed": 1,
      "DefaultMachineDuration": 10,
      "profit_formula": "productTableProfit * (1 + usedCreditNum + factoryBoost + supplyBoost + vehicleBoost + labBuff) * moneyBoostFactor"
    },
    "edge_cases": [
      "Supply 머신 없이 시작 시 기본 공급 속도 적용",
      "모든 슬롯이 비어있으면 생산 불가",
      "Transporter 가득 찼을 때 제품은 라인에 대기"
    ],
